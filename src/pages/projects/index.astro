---
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectFilter from "../../components/ProjectFilter.tsx";
import KineticMarquee from "../../components/KineticMarquee.astro";

const allProjects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
const projects = await Promise.all(
  allProjects.map(async (project) => {
    const optimized = await getImage({ src: project.data.heroImage, width: 960 });
    return {
      id: project.id,
      title: project.data.title,
      eyebrow: project.data.eyebrow,
      category: project.data.eyebrow.split("·")[0].trim(),
      summary: project.data.summary,
      imageSrc: optimized.src,
      imageAlt: project.data.heroImageAlt,
    };
  })
);
---

<BaseLayout
  title="Case Studies | M Shafri Syamsuddin"
  description="Computer vision and NLP case studies by M Shafri Syamsuddin, covering diagnostic imaging, MLOps deployment, and NLP analytics pipelines."
>
  <section id="projects" class="archive-hero">
    <div class="archive-hero-grid" aria-hidden="true"></div>
    <div class="archive-hero-meta"><span>[01] CASE STUDY ARCHIVE</span><span>{String(projects.length).padStart(2, "0")} RECORDS</span></div>
    <h1 data-kinetic>PROJECTS</h1>
    <div class="archive-hero-bottom">
      <p>Research methods translated into deployed, production-aware systems.</p>
      <span>SCROLL TO FILTER ↓</span>
    </div>
  </section>
  <KineticMarquee text="COMPUTER VISION / NLP / MLOPS" dark />
  <section class="archive-section">
    <ProjectFilter client:load projects={projects} />
  </section>
</BaseLayout>
