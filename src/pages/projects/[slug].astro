---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import KineticMarquee from "../../components/KineticMarquee.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({ params: { slug: project.id }, props: { project, allProjects: projects } }));
}

const { project, allProjects } = Astro.props;
const { Content } = await render(project);
const sorted = [...allProjects].sort((a, b) => a.data.order - b.data.order);
const currentIndex = sorted.findIndex((entry) => entry.id === project.id);
const nextProject = sorted[(currentIndex + 1) % sorted.length];
const caseNumber = String(currentIndex + 1).padStart(2, "0");
---

<BaseLayout title={`${project.data.title} | M Shafri Syamsuddin`} description={project.data.summary}>
  <article class="case-page">
    <header class="case-hero">
      <div class="case-hero-grid" aria-hidden="true"></div>
      <div class="case-back-row">
        <a href="/projects">← PROJECT ARCHIVE</a>
        <span>CASE // {caseNumber}</span>
      </div>
      <p class="case-eyebrow">{project.data.eyebrow}</p>
      <h1 data-kinetic>{project.data.title}</h1>
      <div class="case-summary"><span>PROJECT BRIEF</span><p>{project.data.summary}</p></div>
    </header>

    <div class="case-image" data-image-reveal>
      <Image src={project.data.heroImage} alt={project.data.heroImageAlt} width={1800} />
      <span class="case-image-code">FIG // {caseNumber}.A</span>
    </div>

    <section class="case-metrics" aria-label="Project metrics">
      {project.data.metrics.map((metric, index) => (
        <div data-reveal><span>METRIC / 0{index + 1}</span><strong>{metric.value}</strong><p>{metric.label}</p></div>
      ))}
    </section>

    <KineticMarquee text={`${project.data.title} / CASE ${caseNumber}`} reverse />

    <section class="case-body">
      <aside><span>CASE CONTENT</span><p>Research, implementation, results, and deployment considerations.</p></aside>
      <div class="prose prose-case"><Content /></div>
    </section>

    <section class="case-links">
      <span>EXTERNAL RESOURCES</span>
      <div>
        {project.data.links.map((link) => (
          <a href={link.href} target="_blank" rel="noopener" class="action-button"><span>{link.label}</span><b>↗</b></a>
        ))}
      </div>
    </section>

    <a href={`/projects/${nextProject.id}`} class="next-case">
      <span>NEXT CASE STUDY // {String((currentIndex + 1) % sorted.length + 1).padStart(2, "0")}</span>
      <strong>{nextProject.data.title}</strong>
      <i>↗</i>
    </a>
  </article>
</BaseLayout>
