---
import SectionHeading from "./SectionHeading.astro";
import SectionGlow from "./SectionGlow.astro";
import { publications } from "../data/publications";
---

<section id="publications" class="relative py-32">
  <SectionGlow colorA="bg-accent-2/25" colorB="bg-accent-3/20" flip />
  <div class="container-shell relative z-10">
    <SectionHeading
      eyebrow="Publications & Recognition"
      title="Research translated into talks, proceedings, and IP."
      description="Conference contributions and documentation that highlight how laboratory research turns into real-world tooling."
    />

    <div class="grid gap-16 md:grid-cols-2">
      {publications.map((pub, index) => (
        <div>
          <a
            href={pub.linkHref}
            target="_blank"
            rel="noopener"
            data-scrub={index % 2 === 0 ? "photo-left" : "photo-right"}
            class="photo-frame mb-6 block"
          >
            <img src={pub.image} alt={pub.title} class="aspect-[4/3] w-full object-cover" />
          </a>
          <div data-reveal>
            <h3 class="mb-2 font-display text-xl font-bold text-ink">{pub.title}</h3>
            <p class="mb-3 text-muted">{pub.description}</p>
            <a href={pub.linkHref} target="_blank" rel="noopener" class="border-b-2 border-accent pb-0.5 font-display font-bold text-accent">
              {pub.linkLabel} &rarr;
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
