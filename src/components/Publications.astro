---
import SectionHeading from "./SectionHeading.astro";
import { publications } from "../data/publications";
---

<section id="publications" class="portfolio-section publication-section">
  <div class="section-shell">
    <SectionHeading
      index="02"
      eyebrow="Publications & Recognition"
      title="Knowledge made visible."
      description="Conference contributions and documentation showing how experimental work becomes credible, shareable research."
    />

    <div class="publication-grid">
      {publications.map((publication, index) => (
        <article class="publication-card" data-reveal>
          <a href={publication.linkHref} target="_blank" rel="noopener" class="publication-image" data-image-reveal>
            <img src={publication.image} alt={publication.title} loading="lazy" />
            <span>0{index + 1}</span>
          </a>
          <div class="publication-meta"><span>OUTPUT / 0{index + 1}</span><span>2025</span></div>
          <h3>{publication.title}</h3>
          <p>{publication.description}</p>
          <a href={publication.linkHref} target="_blank" rel="noopener" class="inline-link">
            <span>{publication.linkLabel}</span><b>↗</b>
          </a>
        </article>
      ))}
    </div>
  </div>
  <div class="publication-watermark" aria-hidden="true" data-parallax="-5">RESEARCH</div>
</section>
