---
import ContactForm from "./ContactForm.tsx";
import { socials, email } from "../data/socials";
---

<section
  id="contact"
  class="contact-section"
  data-story-screen
  data-story-key="contact"
  data-story-group="contact"
  data-story-title="Contact"
>
  <div class="contact-grid" aria-hidden="true"></div>
  <div class="contact-header" data-reveal>
    <span>[06] CONTACT CHANNEL</span>
    <span>STATUS // OPEN</span>
  </div>

  <div class="contact-layout">
    <div class="contact-intro" data-story-frame="contact-intro">
      <p class="contact-kicker">LET'S BUILD SOMETHING USEFUL.</p>
      <h2 data-kinetic>START A<br />CONVERSATION.</h2>
      <p>
        Open to engineering roles, research collaborations, and projects across computer vision, NLP, and MLOps.
      </p>
      <a href={`mailto:${email}`} class="contact-email">{email}<span>↗</span></a>
      <div class="contact-socials">
        {socials.map((social, index) => (
          <a href={social.href} target="_blank" rel="noopener"><small>0{index + 1}</small>{social.label}<span>↗</span></a>
        ))}
      </div>
    </div>

    <div class="contact-form-shell" data-reveal data-story-frame="contact-form">
      <div class="contact-form-head"><span>SECURE MESSAGE FORM</span><span>ENCRYPTION // TLS</span></div>
      <ContactForm client:visible />
    </div>
  </div>
</section>
