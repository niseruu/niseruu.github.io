---
import SectionHeading from "./SectionHeading.astro";
import { techStack } from "../data/techStack";

const allItems = techStack.flatMap((category) => category.items);
---

<section
  id="tech-stack"
  class="portfolio-section stack-section"
  data-flow-scene
  data-flow-chapter="tech-stack"
  data-flow-label="Capabilities"
  data-flow-code="CP-01"
  data-flow-transition="matrix"
>
  <div class="stack-ticker" aria-hidden="true">
    <div class="stack-ticker-track">
      {[...allItems, ...allItems].map((item) => (
        <span><img src={`/icons/${item.icon}`} alt="" />{item.name}<i>+</i></span>
      ))}
    </div>
  </div>

  <div class="section-shell">
    <SectionHeading
      index="04"
      eyebrow="Capabilities & Tooling"
      title="The machinery behind the work."
      description="A practical stack spanning model development, evaluation, serving, automation, and analytical communication."
    />

    <div class="stack-grid">
      {techStack.map((category, index) => (
        <article class="stack-category" data-reveal data-flow-panel="module">
          <header><span>0{index + 1}</span><h3>{category.title}</h3></header>
          <div class="stack-items">
            {category.items.map((item) => (
              <span class="stack-item"><img src={`/icons/${item.icon}`} alt="" width="24" height="24" /><b>{item.name}</b></span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
