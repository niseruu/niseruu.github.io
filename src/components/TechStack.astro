---
import SectionHeading from "./SectionHeading.astro";
import { techStack } from "../data/techStack";

const allItems = techStack.flatMap((category) => category.items);
const toolCount = allItems.length;
const moduleCapacity = Math.max(...techStack.map((category) => category.items.length));
---

<section
  id="tech-stack"
  class="portfolio-section stack-section"
  data-flow-scene
  data-flow-chapter="tech-stack"
  data-flow-label="Capability Modules / Tech Stack"
  data-flow-code="CP-01"
  data-flow-transition="matrix"
>
  <div class="stack-ticker" aria-hidden="true">
    <div class="stack-ticker-track">
      {[...allItems, ...allItems].map((item) => (
        <span><img src={`/icons/${item.icon}`} alt="" />{item.name}<i>+</i></span>
      ))}
    </div>
  </div>

  <div class="section-shell">
    <SectionHeading
      index="04"
      eyebrow="Capability Modules / Tech Stack"
      title="The machinery behind the work."
      description="A practical stack spanning model development, evaluation, serving, automation, and analytical communication."
    />

    <div class="stack-matrix-head" data-stack-head aria-hidden="true">
      <span>CAPABILITY MATRIX / ACTIVE</span>
      <i></i>
      <span>{String(techStack.length).padStart(2, "0")} MODULES</span>
      <span>{String(toolCount).padStart(2, "0")} TOOLS</span>
    </div>

    <div class="stack-grid" data-stack-matrix>
      {techStack.map((category, index) => (
        <article class="stack-category" data-reveal data-stack-module data-stack-domain={category.domain}>
          <i class="stack-module-rule" data-stack-rule aria-hidden="true"></i>
          <header>
            <span>[CP-{String(index + 1).padStart(2, "0")}]</span>
            <div>
              <small>{category.domain}</small>
              <h3>{category.title}</h3>
            </div>
            <b>{category.status} / {String(category.items.length).padStart(2, "0")}</b>
          </header>
          <div class="stack-items">
            {category.items.map((item, itemIndex) => (
              <span class="stack-item" data-stack-item>
                <small>{String(itemIndex + 1).padStart(2, "0")}</small>
                <img src={`/icons/${item.icon}`} alt="" width="24" height="24" />
                <b>{item.name}</b>
              </span>
            ))}
            {Array.from({ length: moduleCapacity - category.items.length }, (_, slotIndex) => (
              <span class="stack-item stack-item--empty" data-stack-item aria-hidden="true">
                <small>{String(category.items.length + slotIndex + 1).padStart(2, "0")}</small>
                <i aria-hidden="true">+</i>
                <b>OPEN SLOT</b>
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
