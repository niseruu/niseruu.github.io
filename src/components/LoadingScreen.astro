<div
  id="site-loader"
  class="site-loader"
  aria-hidden="true"
  aria-live="polite"
  transition:persist="site-loader"
>
  <div class="loader-grid" aria-hidden="true"></div>

  <div class="loader-topline">
    <span>SYS // PORTFOLIO INTERFACE</span>
    <span>JKT — IDN</span>
  </div>

  <div class="loader-mark" aria-label="M Shafri Syamsuddin">
    <span>M</span><span>S</span>
  </div>

  <div class="loader-center" aria-hidden="true">
    <span class="loader-cross">+</span>
    <span>INITIALISING EXPERIENCE</span>
    <span class="loader-cross">+</span>
  </div>

  <div class="loader-progress">
    <div class="loader-progress-meta">
      <span data-loader-status>LOADING IMAGES</span>
      <span><strong data-loader-value>00</strong>%</span>
    </div>
    <div class="loader-track"><span data-loader-bar></span></div>
  </div>
</div>
