---
import { Image } from "astro:assets";
import portrait from "../assets/images/portrait-cutout-v2.png";
import KineticMarquee from "./KineticMarquee.astro";
---

<section id="hero" class="hero-section">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="hero-corner hero-corner--one" aria-hidden="true">+</div>
  <div class="hero-corner hero-corner--two" aria-hidden="true">+</div>

  <div class="hero-topline">
    <p data-hero-reveal>PORTFOLIO / 2026</p>
    <p data-hero-reveal>COMPUTER VISION · NLP · APPLIED AI</p>
    <p data-hero-reveal>JAKARTA, INDONESIA <span class="status-dot"></span></p>
  </div>

  <div class="hero-title" aria-label="Shafri Syamsuddin">
    <h1>
      <span class="hero-title-line hero-title-line--first"><span data-hero-reveal>SHAFRI</span></span>
      <span class="hero-title-line hero-title-line--second"><span data-hero-reveal>SYAMSUDDIN</span></span>
    </h1>
  </div>

  <div class="hero-image-zone" data-hero-reveal>
    <div class="hero-image-yellow" aria-hidden="true"></div>
    <div class="hero-image-frame">
      <Image
        src={portrait}
        alt="Portrait of M Shafri Syamsuddin"
        width={800}
        loading="eager"
        data-loader-hero
      />
      <div class="hero-image-scan" aria-hidden="true"></div>
    </div>
    <span class="hero-image-label">SUBJECT // MSS-001</span>
  </div>

  <div class="hero-role" data-hero-reveal>
    <span>ROLE / SPECIALISATION</span>
    <strong>AI ENGINEER</strong>
    <p>Building production-aware vision and language systems from research to deployment.</p>
  </div>

  <div class="hero-actions" data-hero-reveal>
    <a href="/projects" class="action-button action-button--dark"><span>Explore work</span><b>↗</b></a>
    <a href="/docs/m-shafri-syamsuddin-cv.pdf" target="_blank" rel="noopener" class="action-button"><span>Download CV</span><b>↓</b></a>
    <a href="mailto:shafrisyamsuddin@gmail.com" class="text-action">AVAILABLE FOR COLLABORATION <b>↗</b></a>
  </div>

  <a href="#projects" class="hero-scroll" aria-label="Scroll to case studies">
    <span>SCROLL TO EXPLORE</span><i>↓</i>
  </a>
</section>

<KineticMarquee text="VISION / LANGUAGE / DEPLOY" />
