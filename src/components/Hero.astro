---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import portrait from "../assets/images/portrait-cutout-v2.png";
import { publications } from "../data/publications";
import KineticMarquee from "./KineticMarquee.astro";

const featuredProjectCount = (await getCollection("projects")).filter(
  (project) => project.data.featured,
).length;
const researchRecordCount = publications.length;
const formatCount = (count: number) => String(count).padStart(2, "0");
---

<section
  id="hero"
  class="hero-section"
  data-flow-scene
  data-flow-chapter="hero"
  data-flow-label="Identity"
  data-flow-code="ID-00"
  data-flow-transition="identity"
>
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="hero-instrument hero-instrument--asset" aria-hidden="true">
    <span>PROFILE IMAGE</span>
    <strong>1024 × 1536 / RGBA</strong>
  </div>
  <div class="hero-instrument hero-instrument--base" aria-hidden="true">
    <span>LOCAL BASE</span>
    <strong>JAKARTA / ID</strong>
  </div>

  <div class="hero-topline" data-flow-panel="metadata">
    <p data-hero-reveal>PORTFOLIO / 2026</p>
    <p data-hero-reveal>COMPUTER VISION · NLP · APPLIED AI</p>
    <p data-hero-reveal>STATUS / AVAILABLE <span class="status-dot"></span></p>
  </div>

  <div class="hero-title" aria-label="Shafri Syamsuddin" data-flow-panel="title">
    <h1 data-flow-title>
      <span class="hero-title-line hero-title-line--first"><span data-hero-reveal>SHAFRI</span></span>
      <span class="hero-title-line hero-title-line--second"><span data-hero-reveal>SYAMSUDDIN</span></span>
    </h1>
  </div>

  <div class="hero-image-zone" data-flow-panel="subject">
    <div class="hero-image-yellow" aria-hidden="true"></div>
    <div class="hero-image-frame">
      <div class="hero-image-subject">
        <Image
          src={portrait}
          alt="Portrait of M Shafri Syamsuddin"
          width={800}
          loading="eager"
          fetchpriority="high"
          data-loader-image
          data-loader-hero
        />
      </div>
      <div class="hero-image-scan" aria-hidden="true"></div>
    </div>
    <span class="hero-image-label">SUBJECT // MSS-001</span>
  </div>

  <div class="hero-role" data-hero-reveal data-flow-panel="stats">
    <div class="hero-dossier-header">
      <span>PROFILE RECORD // MSS-001</span>
      <b>AVAILABLE</b>
    </div>

    <div class="hero-dossier-primary">
      <span>ROLE / SPECIALISATION</span>
      <strong>AI ENGINEER</strong>
      <p>Building production-aware vision and language systems from research to deployment.</p>
    </div>

    <dl class="hero-dossier-grid">
      <div>
        <dt>BASE</dt>
        <dd>JAKARTA / ID</dd>
      </div>
      <div>
        <dt>FOCUS</dt>
        <dd>VISION + NLP</dd>
      </div>
      <div>
        <dt>PROJECT FILES</dt>
        <dd>{formatCount(featuredProjectCount)}</dd>
      </div>
      <div>
        <dt>RESEARCH RECORDS</dt>
        <dd>{formatCount(researchRecordCount)}</dd>
      </div>
    </dl>
  </div>

  <div class="hero-actions" data-hero-reveal data-flow-panel="actions">
    <a href="/projects" class="action-button action-button--dark"><span>Explore work</span><b>↗</b></a>
    <a href="/docs/m-shafri-syamsuddin-cv.pdf" target="_blank" rel="noopener" class="action-button"><span>Download CV</span><b>↓</b></a>
    <a href="mailto:shafrisyamsuddin@gmail.com" class="text-action">AVAILABLE FOR COLLABORATION <b>↗</b></a>
  </div>

  <a href="/#projects" class="hero-scroll" data-nav-section="projects" aria-label="Scroll to case studies">
    <span>SCROLL TO EXPLORE</span><i>↓</i>
  </a>
</section>

<KineticMarquee text="VISION / LANGUAGE / DEPLOY" />
