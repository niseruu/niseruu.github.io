<aside id="sidebar" class="desktop-rail" transition:persist="desktop-rail">
  <div class="rail-surface">
    <a href="/#hero" class="rail-logo" aria-label="M Shafri Syamsuddin — Home">
      <span>M</span><span>S</span><small>PORTFOLIO</small>
    </a>

    <nav class="rail-nav" aria-label="Primary navigation">
      {links.map((link) => (
        <a href={link.href} class="rail-link" data-nav-section={link.section}>
          <span class="rail-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square" stroke-linejoin="miter" set:html={link.icon} />
          </span>
          <span class="rail-label"><small>{link.code}</small>{link.label}</span>
        </a>
      ))}
    </nav>

    <div class="rail-utilities">
      <div class="rail-socials" aria-label="Social links">
        <a href="https://github.com/Shafriii" target="_blank" rel="noopener" aria-label="GitHub">GH</a>
        <a href="https://www.linkedin.com/in/shafrisyamsuddin/" target="_blank" rel="noopener" aria-label="LinkedIn">IN</a>
        <a href="https://medium.com/@shafrisyamsuddin" target="_blank" rel="noopener" aria-label="Medium">MD</a>
