    <button id="menu-toggle" class="menu-toggle" aria-label="Open navigation" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span>
    </button>
  </div>
</header>

<nav id="mobile-menu" class="mobile-menu" data-open="false" aria-label="Mobile navigation" transition:persist="mobile-menu">
  <div class="mobile-menu-grid" aria-hidden="true"></div>
  <p class="mobile-menu-kicker">SELECT DESTINATION // 00—06</p>
  <div class="mobile-menu-links">
    {links.map((link) => (
      <a href={link.href} data-nav-section={link.section}>
        <small>{link.code}</small><span>{link.label}</span><i>↗</i>
      </a>
    ))}
  </div>
  <div class="mobile-menu-foot">
    <a href="mailto:shafrisyamsuddin@gmail.com">EMAIL</a>
    <a href="https://github.com/Shafriii" target="_blank" rel="noopener">GITHUB</a>
