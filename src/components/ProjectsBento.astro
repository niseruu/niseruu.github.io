---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import SectionHeading from "./SectionHeading.astro";
import KineticMarquee from "./KineticMarquee.astro";

const projects = (await getCollection("projects"))
  .filter((project) => project.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
const projectAnchors = ["project-malaria", "project-visionserve", "project-sentiment"];
---

<section
  id="projects"
  class="portfolio-section projects-section"
  data-flow-scene
  data-flow-chapter="projects"
  data-flow-label="Case Studies"
  data-flow-code="CS-01"
  data-flow-transition="cases"
>
  <div class="section-shell">
    <SectionHeading
      index="01"
      eyebrow="Selected Case Studies"
      title="Research engineered for the real world."
      description="Applied machine-learning systems built with deployment, reproducibility, and measurable outcomes in mind."
    />

    <nav class="project-record-strip" aria-label="Selected case studies" data-flow-panel="records">
      {projects.map((project, index) => (
        <a href={`#${projectAnchors[index]}`} data-project-jump={index}>
          <small>{String(index + 1).padStart(2, "0")}</small>
          <span>{project.data.title}</span>
          <i aria-hidden="true"></i>
        </a>
      ))}
    </nav>

    <div class="project-list">
      {projects.map((project, index) => (
        <article
          id={projectAnchors[index]}
          class:list={["project-feature", index % 2 === 1 && "project-feature--reverse"]}
          data-flow-record
          data-flow-record-index={index}
        >
          <a href={`/projects/${project.id}`} class="project-media" data-image-reveal data-flow-panel="media">
          <Image
            src={project.data.heroImage}
            alt={project.data.heroImageAlt}
            width={1200}
            class="project-image"
            loading="eager"
            data-loader-image
          />
          <span class="project-media-index">0{index + 1}</span>
          <span class="project-media-arrow">↗</span>
          <span class="project-media-grid" aria-hidden="true"></span>
          </a>

          <div class="project-copy" data-reveal data-flow-panel="data">
            <div class="project-kicker">
              <span>CASE // 0{index + 1}</span>
              <span>{project.data.eyebrow}</span>
            </div>
            <h3>
              <a href={`/projects/${project.id}`} class="project-title-link">
                <span data-flow-title>{project.data.title}</span>
              </a>
            </h3>
            <p>{project.data.summary}</p>

            <div class="project-metrics">
              {project.data.metrics.map((metric, metricIndex) => (
                <div data-flow-metric>
                  <small>0{metricIndex + 1}</small>
                  <strong>{metric.value}</strong>
                  <span>{metric.label}</span>
                </div>
              ))}
            </div>

            <a href={`/projects/${project.id}`} class="inline-link"><span>Open case study</span><b>↗</b></a>
          </div>
        </article>
      ))}
    </div>

    <div class="section-end-action" data-reveal data-flow-panel="archive">
      <span>03 PROJECTS / FULL ARCHIVE</span>
      <a href="/projects" class="action-button action-button--yellow"><span>View all case studies</span><b>↗</b></a>
    </div>
  </div>
</section>

<KineticMarquee text="RESEARCH / SYSTEMS / IMPACT" reverse dark />
