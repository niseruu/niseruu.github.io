---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import portrait from "../assets/images/portrait-cutout-v2.png";
import ContactForm from "./ContactForm.tsx";
import { publications } from "../data/publications";
import { journey } from "../data/journey";
import { techStack } from "../data/techStack";
import { scores } from "../data/scores";
import { socials, email } from "../data/socials";
import { dossierChapterTargets, dossierPages } from "../data/dossierPages";

const projects = (await getCollection("projects"))
  .filter((project) => project.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
const projectPages = projects.map((project, index) => ({ project, page: dossierPages[index + 1] }));
const journeyPages = Array.from({ length: 4 }, (_, index) => ({
  page: dossierPages[index + 5],
  entries: journey.slice(index * 2, index * 2 + 2),
  offset: index * 2,
}));
const capabilityPages = Array.from({ length: 2 }, (_, index) => ({
  page: dossierPages[index + 9],
  categories: techStack.slice(index * 2, index * 2 + 2),
  offset: index * 2,
}));
const researchPage = dossierPages[4];
const scoresPage = dossierPages[11];
const contactPage = dossierPages[12];
const formPage = dossierPages[13];
const year = new Date().getFullYear();
---

<div class="operator-deck" data-operator-deck>
  <div class="operator-stage" data-operator-stage>
    <div class="operator-grid" aria-hidden="true"></div>

    <div class="operator-index" data-operator-index>
      <div class="operator-index-brand"><strong>MS</strong><span>OPERATOR FILE</span></div>
      <nav class="operator-chapters" aria-label="Dossier chapters">
        {dossierChapterTargets.map((chapter) => (
          <button type="button" data-dossier-target={chapter.target}>
            <small>{chapter.code}</small><span>{chapter.label}</span>
          </button>
        ))}
      </nav>
      <div class="operator-page-track" aria-label="Dossier pages">
        {dossierPages.map((page, index) => (
          <button
            type="button"
            data-dossier-target={page.id}
            aria-label={`Open page ${index + 1}: ${page.title}`}
            title={page.title}
          ><i></i></button>
        ))}
      </div>
      <div class="operator-index-status">
        <span data-dossier-current>01</span><i>/</i><span>{String(dossierPages.length).padStart(2, "0")}</span>
        <b data-dossier-code>{dossierPages[0].code}</b>
      </div>
      <div class="operator-index-controls">
        <button type="button" data-dossier-prev aria-label="Previous dossier page">←</button>
        <button type="button" data-dossier-next aria-label="Next dossier page">→</button>
      </div>
    </div>

    <div class="operator-viewport" data-operator-viewport>
      <section
        id="hero"
        class="operator-page operator-page--identity"
        data-dossier-page
        data-dossier-id="identity"
        data-dossier-hash="hero"
        data-dossier-section="hero"
        data-dossier-title="Operator Profile"
      >
        <header class="operator-page-head" data-dossier-zone>
          <span>[ IDENTITY RECORD ]</span><span>SUBJECT // MSS-001</span><span>STATUS // AVAILABLE</span>
        </header>
        <div class="operator-hero-copy" data-dossier-zone>
          <p class="operator-kicker">COMPUTER VISION · NLP · APPLIED AI</p>
          <h1 data-dossier-display>SHAFRI<br /><span>SYAMSUDDIN</span></h1>
          <div class="operator-role-plate">
            <small>PRIMARY DESIGNATION</small><strong>AI ENGINEER</strong>
            <p>Building production-aware vision and language systems from research to deployment.</p>
          </div>
        </div>
        <figure class="operator-portrait" data-dossier-zone>
          <div class="operator-target operator-target--one" aria-hidden="true">+</div>
          <div class="operator-target operator-target--two" aria-hidden="true">+</div>
          <div class="operator-portrait-signal" aria-hidden="true"></div>
          <Image src={portrait} alt="Portrait of M Shafri Syamsuddin" width={900} loading="eager" fetchpriority="high" data-loader-image data-loader-hero />
          <figcaption><span>JAKARTA / INDONESIA</span><span>LOCAL TIME // UTC+07</span></figcaption>
        </figure>
        <div class="operator-hero-actions" data-dossier-zone>
          <a href="/#projects" data-nav-section="projects" class="operator-command">VIEW OPERATIONS <b>→</b></a>
          <a href="/docs/m-shafri-syamsuddin-cv.pdf" target="_blank" rel="noopener">OPEN RÉSUMÉ ↗</a>
          <a href={`mailto:${email}`}>EMAIL ↗</a>
        </div>
        <div class="operator-vertical-word" aria-hidden="true">OPERATOR</div>
      </section>

      {projectPages.map(({ project, page }, index) => (
        <section
          id={page.hash}
          class:list={["operator-page", "operator-page--project", index % 2 === 1 && "operator-page--mirror"]}
          data-dossier-page
          data-dossier-id={page.id}
          data-dossier-hash={page.hash}
          data-dossier-section={page.section}
          data-dossier-title={page.title}
        >
          <header class="operator-page-head" data-dossier-zone>
            <span>[ SELECTED OPERATION ]</span><span>{page.code}</span><span>FILE // 0{index + 1} / 03</span>
          </header>
          <a href={`/projects/${project.id}`} class="operator-project-media" data-dossier-zone>
            <Image src={project.data.heroImage} alt={project.data.heroImageAlt} width={1400} class="operator-project-image" loading="eager" data-loader-image />
            <span class="operator-media-grid" aria-hidden="true"></span>
            <span class="operator-media-code">VISUAL RECORD // {page.code}</span>
          </a>
          <div class="operator-project-copy" data-dossier-zone>
            <p class="operator-kicker">{project.data.eyebrow}</p>
            <h2 data-dossier-display>{project.data.title}</h2>
            <p class="operator-project-summary">{project.data.summary}</p>
            <div class="operator-metrics">
              {project.data.metrics.map((metric, metricIndex) => (
                <div><small>0{metricIndex + 1}</small><strong>{metric.value}</strong><span>{metric.label}</span></div>
              ))}
            </div>
            <a href={`/projects/${project.id}`} class="operator-command">OPEN CASE STUDY <b>↗</b></a>
            {index === projects.length - 1 && <a href="/projects" class="operator-archive-link">VIEW FULL ARCHIVE ↗</a>}
          </div>
          <div class="operator-page-number" aria-hidden="true">0{index + 1}</div>
        </section>
      ))}

      <section
        id={researchPage.hash}
        class="operator-page operator-page--research"
        data-dossier-page
        data-dossier-id={researchPage.id}
        data-dossier-hash={researchPage.hash}
        data-dossier-section={researchPage.section}
        data-dossier-title={researchPage.title}
      >
        <header class="operator-page-head" data-dossier-zone>
          <span>[ RESEARCH ARCHIVE ]</span><span>{researchPage.code}</span><span>OUTPUTS // 02</span>
        </header>
        <div class="operator-section-title" data-dossier-zone>
          <p class="operator-kicker">PUBLICATIONS & RECOGNITION</p>
          <h2 data-dossier-display>KNOWLEDGE<br />MADE VISIBLE.</h2>
          <p>Conference contributions and documentation showing how experimental work becomes credible, shareable research.</p>
        </div>
        <div class="operator-publication-list" data-dossier-zone>
          {publications.map((publication, index) => (
            <article>
              <a href={publication.linkHref} target="_blank" rel="noopener" class="operator-publication-image">
                <img src={publication.image} alt={publication.title} loading="eager" decoding="async" data-loader-image />
                <span>0{index + 1}</span>
              </a>
              <div><small>OUTPUT / 0{index + 1} · 2025</small><h3>{publication.title}</h3><p>{publication.description}</p><a href={publication.linkHref} target="_blank" rel="noopener">{publication.linkLabel} ↗</a></div>
            </article>
          ))}
        </div>
      </section>

      {journeyPages.map(({ page, entries, offset }, pageIndex) => (
        <section
          id={page.hash}
          class="operator-page operator-page--journey"
          data-dossier-page
          data-dossier-id={page.id}
          data-dossier-hash={page.hash}
          data-dossier-section={page.section}
          data-dossier-title={page.title}
        >
          <header class="operator-page-head" data-dossier-zone>
            <span>[ EXPERIENCE & EDUCATION ]</span><span>{page.code}</span><span>SEQUENCE // 0{pageIndex + 1} / 04</span>
          </header>
          <div class="operator-section-title" data-dossier-zone>
            <p class="operator-kicker">JOURNEY LOG</p>
            <h2 data-dossier-display>{page.title}</h2>
            <p>A path through code, research, product leadership, and applied machine learning.</p>
          </div>
          <ol class="operator-journey-pair" data-dossier-zone>
            {entries.map((entry, index) => (
              <li>
                <div class="operator-journey-index"><span>{String(offset + index + 1).padStart(2, "0")}</span><i></i></div>
                <div><small>{entry.period}</small><h3>{entry.title}</h3><p>{entry.description}</p></div>
              </li>
            ))}
          </ol>
          <div class="operator-journey-map" aria-hidden="true"><i></i><i></i><i></i><i></i></div>
        </section>
      ))}

      {capabilityPages.map(({ page, categories, offset }, pageIndex) => (
        <section
          id={page.hash}
          class="operator-page operator-page--capabilities"
          data-dossier-page
          data-dossier-id={page.id}
          data-dossier-hash={page.hash}
          data-dossier-section={page.section}
          data-dossier-title={page.title}
        >
          <header class="operator-page-head" data-dossier-zone>
            <span>[ CAPABILITY MATRIX ]</span><span>{page.code}</span><span>LOADOUT // 0{pageIndex + 1} / 02</span>
          </header>
          <div class="operator-section-title" data-dossier-zone>
            <p class="operator-kicker">CAPABILITIES & TOOLING</p>
            <h2 data-dossier-display>{page.title}</h2>
            <p>A practical stack spanning model development, evaluation, serving, automation, and analytical communication.</p>
          </div>
          <div class="operator-capability-grid" data-dossier-zone>
            {categories.map((category, index) => (
              <article>
                <header><span>0{offset + index + 1}</span><h3>{category.title}</h3><small>{String(category.items.length).padStart(2, "0")} MODULES</small></header>
                <div>
                  {category.items.map((item, itemIndex) => (
                    <span><small>{String(itemIndex + 1).padStart(2, "0")}</small><img src={`/icons/${item.icon}`} alt="" width="28" height="28" /><b>{item.name}</b></span>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}

      <section
        id={scoresPage.hash}
        class="operator-page operator-page--scores"
        data-dossier-page
        data-dossier-id={scoresPage.id}
        data-dossier-hash={scoresPage.hash}
        data-dossier-section={scoresPage.section}
        data-dossier-title={scoresPage.title}
      >
        <header class="operator-page-head" data-dossier-zone>
          <span>[ VERIFIED BENCHMARKS ]</span><span>{scoresPage.code}</span><span>RECORDS // 02</span>
        </header>
        <div class="operator-section-title" data-dossier-zone>
          <p class="operator-kicker">SIGNALS, MEASURED.</p>
          <h2 data-dossier-display>VERIFIED<br />SIGNALS.</h2>
        </div>
        <div class="operator-score-plates" data-dossier-zone>
          {scores.map((score, index) => (
            <a href={score.reportHref} target="_blank" rel="noopener">
              <header><span>REPORT / 0{index + 1}</span><span>VERIFIED ↗</span></header>
              <strong>{score.value}</strong><div><h3>{score.name}</h3><p>{score.meta}</p></div>
            </a>
          ))}
        </div>
      </section>

      <section
        id={contactPage.hash}
        class="operator-page operator-page--contact"
        data-dossier-page
        data-dossier-id={contactPage.id}
        data-dossier-hash={contactPage.hash}
        data-dossier-section={contactPage.section}
        data-dossier-title={contactPage.title}
      >
        <header class="operator-page-head" data-dossier-zone>
          <span>[ CONTACT CHANNEL ]</span><span>{contactPage.code}</span><span>STATUS // OPEN</span>
        </header>
        <div class="operator-contact-main" data-dossier-zone>
          <p class="operator-kicker">LET'S BUILD SOMETHING USEFUL.</p>
          <h2 data-dossier-display>START A<br />CONVERSATION.</h2>
          <p>Open to engineering roles, research collaborations, and projects across computer vision, NLP, and MLOps.</p>
          <a href={`mailto:${email}`} class="operator-contact-email">{email}<b>↗</b></a>
        </div>
        <div class="operator-contact-links" data-dossier-zone>
          {socials.map((social, index) => (
            <a href={social.href} target="_blank" rel="noopener"><small>0{index + 1}</small><span>{social.label}</span><b>↗</b></a>
          ))}
          <button type="button" data-dossier-target="contact-form" class="operator-command">OPEN SECURE FORM <b>→</b></button>
        </div>
      </section>

      <section
        id={formPage.hash}
        class="operator-page operator-page--form"
        data-dossier-page
        data-dossier-id={formPage.id}
        data-dossier-hash={formPage.hash}
        data-dossier-section={formPage.section}
        data-dossier-title={formPage.title}
      >
        <header class="operator-page-head" data-dossier-zone>
          <span>[ SECURE MESSAGE FORM ]</span><span>{formPage.code}</span><span>ENCRYPTION // TLS</span>
        </header>
        <div class="operator-form-title" data-dossier-zone>
          <p class="operator-kicker">FINAL DOSSIER PAGE</p>
          <h2 data-dossier-display>TRANSMIT<br />MESSAGE.</h2>
          <p>Your message is sent through the portfolio’s Cloudflare contact endpoint.</p>
        </div>
        <div class="operator-form-shell" data-dossier-zone data-page-interactive>
          <ContactForm client:visible />
        </div>
        <div class="operator-end-state" data-dossier-zone>
          <strong>END OF FILE</strong><span>14 / 14</span><i></i>
        </div>
        <footer class="operator-end-footer" data-dossier-zone>
          <div><strong>MS</strong><span>M SHAFRI SYAMSUDDIN</span></div>
          <p>© {year} / COMPUTER VISION & NLP ENGINEER</p>
          <div>{socials.map((social) => <a href={social.href} target="_blank" rel="noopener">{social.label} ↗</a>)}<a href="/docs/m-shafri-syamsuddin-cv.pdf" target="_blank" rel="noopener">RÉSUMÉ ↗</a></div>
        </footer>
      </section>
    </div>

    <div class="operator-handoff" data-operator-handoff aria-hidden="true">
      <div class="operator-shutter operator-shutter--ink"></div>
      <div class="operator-shutter operator-shutter--paper"></div>
      <div class="operator-shutter operator-shutter--signal"></div>
      <div class="operator-handoff-spine">
        <small data-handoff-from>01</small><i></i><strong data-handoff-to>02</strong>
      </div>
      <div class="operator-handoff-rule operator-handoff-rule--top"></div>
      <div class="operator-handoff-rule operator-handoff-rule--bottom"></div>
    </div>

    <p class="sr-only" aria-live="polite" aria-atomic="true" data-dossier-announcer>Page 1 of 14: Operator Profile</p>
  </div>
</div>
