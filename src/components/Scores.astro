---
import SectionHeading from "./SectionHeading.astro";
import SectionGlow from "./SectionGlow.astro";
import { scores } from "../data/scores";
---

<section id="scores" class="relative py-28">
  <SectionGlow colorA="bg-accent-2/20" colorB="bg-accent-3/25" />
  <div class="container-shell relative z-10">
    <SectionHeading eyebrow="Scores" title="Language and cognitive benchmarks." />

    <div class="grid gap-6 sm:grid-cols-2">
      {scores.map((score) => (
        <div data-reveal class="glass-panel p-8">
          <h3 class="mb-2 font-display text-lg text-ink">{score.name}</h3>
          <p class="font-display mb-2 text-5xl font-bold text-gradient">
            <span data-count={score.numericValue}>0</span>
          </p>
          <p class="mb-6 text-muted">{score.meta}</p>
          <a
            href={score.reportHref}
            target="_blank"
            rel="noopener"
            class="inline-flex border-2 border-border px-5 py-2.5 font-display text-sm font-bold text-ink transition hover:border-accent hover:bg-accent/10"
          >
            View report
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
