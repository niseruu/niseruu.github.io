---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  index?: string;
  align?: "left" | "right";
}

const { eyebrow, title, description, index = "00", align = "left" } = Astro.props;
---

<header class:list={["section-heading", align === "right" && "section-heading--right"]} data-reveal>
  <div class="section-heading-meta">
    <span class="section-index">[{index}]</span>
    <span class="section-eyebrow">{eyebrow}</span>
    <span class="section-signal" aria-hidden="true"></span>
  </div>
  <h2 data-kinetic data-flow-title>{title}</h2>
  {description && <p class="section-description">{description}</p>}
</header>
