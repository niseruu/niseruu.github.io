---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mb-16 max-w-2xl" data-reveal>
  <p class="eyebrow mb-4">{eyebrow}</p>
  <h2 class="mb-4 font-display text-3xl font-semibold text-ink md:text-4xl">{title}</h2>
  {description && <p class="text-lg text-muted">{description}</p>}
</div>
